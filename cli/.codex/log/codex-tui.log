 class PostCreate(BaseModel):
     author: str = "unknown"
     author_role: str = "human"
     content: str = ""
     metadata: dict | None = None
+
+    @staticmethod
+    def _validate_depth(value: object, depth: int = 1) -> None:
+        if depth > 3:
+            raise ValueError("metadata のネストは 3 階層以下にしてください")
+        if isinstance(value, dict):
+            for child in value.values():
+                PostCreate._validate_depth(child, depth + 1)
+        elif isinstance(value, list):
+            for child in value:
+                PostCreate._validate_depth(child, depth + 1)
+
+    @field_validator("metadata")
+    @classmethod
+    def validate_metadata(cls, value: dict | None) -> dict | None:
+        if value is None:
+            return value
+        cls._validate_depth(value)
+        try:
+            serialized = json.dumps(value, ensure_ascii=False)
+        except (TypeError, ValueError) as exc:
+            raise ValueError("metadata は JSON シリアライズ可能な値にしてください") from exc
+        if len(serialized) > 4096:
+            raise ValueError("metadata は 4KB 以下にしてください")
+        return value
